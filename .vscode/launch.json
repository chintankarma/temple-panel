{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Debug Temple Guide (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/src",
            "sourceMapPathOverrides": {
                "/@fs/*": "${workspaceFolder}/*"
            }
        },
        {
            "name": "🔗 Attach to Running Chrome",
            "type": "chrome",
            "request": "attach",
            "port": 9222,
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/src",
            "sourceMapPathOverrides": {
                "/@fs/*": "${workspaceFolder}/*"
            }
        }
    ]
}